# Copy to .env and fill in with your real keys.
# The same 5 vars go into Vercel → Settings → Environment Variables.

# Clerk (dashboard.clerk.com → your app → API keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_ZXhhbXBsZS5jbGVyay5hY2NvdW50cy5kZXYk
# same value as VITE_CLERK_PUBLISHABLE_KEY — this copy is read by the Express server
CLERK_PUBLISHABLE_KEY=pk_test_ZXhhbXBsZS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Stripe TEST mode secret key (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# MongoDB Atlas connection string (db name "fadig" is created automatically)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
